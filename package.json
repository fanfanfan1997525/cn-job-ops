{
  "name": "cn-job-ops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first CLI assistant for domestic job search tracking, evaluation, drafts, and reports.",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "cn-job-ops": "./dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "docs",
    "package.json",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "smoke": "tsx src/cli.ts smoke --workspace .cn-job-ops-smoke",
    "prepublishOnly": "npm test && npm run typecheck && npm run build && npm run smoke"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
